@model IEnumerable<CarInsurance.Models.Insuree>

@{
    ViewBag.Title = "Insurees";
}

<h2>Insurees</h2>

<table class="table">
    <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Quote</th>
    </tr>

    @if (Model != null)
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.EmailAddress</td>
                <td>@item.Quote</td>
            </tr>
        }
    }
</table>
